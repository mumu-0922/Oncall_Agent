# ============================================================
# Oncall_Agent VPS production template
# 复制为 .env.production 后再填真实值：cp .env.production.example .env.production
# 注意：本文件只放占位符，禁止写入真实 API Key / Token。
# ============================================================

# 应用配置
APP_NAME=SuperBizAgent
DEBUG=false
HOST=0.0.0.0
PORT=9900
APP_LOG_FILE=/var/log/oncall-agent/app.log

# Docker Compose 对外端口：nginx 暴露公网，API/MCP/Prometheus 仅绑定 127.0.0.1
NGINX_HTTP_PORT=80
HOST_API_PORT=9900
HOST_MCP_CLS_PORT=8003
HOST_MCP_MONITOR_PORT=8004
HOST_PROMETHEUS_PORT=9090
HOST_ALERTMANAGER_PORT=9093
HOST_NODE_EXPORTER_PORT=9100

# ============================================================
# Chat LLM 配置：生产必须替换占位符，否则 deploy_vps.sh 会拒绝启动
# ============================================================
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://your-gateway.example/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=2

# DashScope / OpenAI 可选备用配置
DASHSCOPE_API_KEY=replace-me
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=
OPENAI_API_KEY=replace-me
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================
# Embedding / RAG：无 embedding key 时保持 disabled，不强依赖 Milvus
# ============================================================
EMBEDDING_PROVIDER=disabled
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1024
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

RAG_TOP_K=3
RAG_RETRIEVAL_MODE=hybrid_parent
RAG_DOCSTORE_DIR=data/rag
RAG_PARENT_MAX_CHARS=3500
RAG_CHILD_CHUNK_SIZE=500
RAG_CHILD_CHUNK_OVERLAP=80
RAG_DENSE_FETCH_K=10
RAG_BM25_FETCH_K=10
RAG_FINAL_TOP_K=3
RAG_DENSE_WEIGHT=0.6
RAG_BM25_WEIGHT=0.4
RAG_EXPAND_PARENT=true
RAG_PARENT_CONTEXT_MAX_CHARS=2500
RAG_MODEL=
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100
RAG_CONTEXT_SUMMARY_ENABLED=true
RAG_SUMMARY_TRIGGER_MESSAGES=12
RAG_SUMMARY_KEEP_MESSAGES=6
RAG_SUMMARY_TRIM_TOKENS=4000

# ============================================================
# AIOps Agent：生产默认禁止 mock，失败直接暴露真实原因
# ============================================================
AIOPS_STRUCTURED_OUTPUT_METHOD=function_calling
AIOPS_REQUIRE_TOOL_CALL=true
AIOPS_TOOL_CALL_MAX_ROUNDS=3
AIOPS_EXECUTOR_SUMMARIZE_WITH_LLM=false
AIOPS_ALLOW_MOCK=false
AIOPS_DEFAULT_SERVICE=oncall-agent

# MCP 服务：容器内监听 0.0.0.0，API 通过 compose service name 访问
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://mcp-cls:8003/mcp
MCP_CLS_HOST=0.0.0.0
MCP_CLS_PORT=8003
MCP_CLS_LOG_FILE=/var/log/oncall-agent/mcp_cls.log

MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://mcp-monitor:8004/mcp
MCP_MONITOR_HOST=0.0.0.0
MCP_MONITOR_PORT=8004
MCP_MONITOR_LOG_FILE=/var/log/oncall-agent/mcp_monitor.log

# 日志白名单：search_local_logs 只读这些路径，不扫描全盘
AIOPS_LOG_PROVIDER=local_vps
AIOPS_SERVICE_LOG_MAP={"oncall-agent":["/var/log/oncall-agent/app.log","/var/log/oncall-agent/mcp_cls.log","/var/log/oncall-agent/mcp_monitor.log"],"nginx":["/var/log/nginx/error.log","/var/log/nginx/access.log"]}
AIOPS_LOCAL_LOG_MAX_RESULTS=200
AIOPS_LOCAL_LOG_MAX_LINES=5000
AIOPS_LOCAL_LOG_MAX_BYTES=2097152

# 指标/告警：VPS 推荐 Prometheus + Alertmanager + node_exporter
AIOPS_MONITOR_PROVIDER=prometheus
AIOPS_PROMETHEUS_URL=http://prometheus:9090
AIOPS_ALERTMANAGER_URL=http://alertmanager:9093
AIOPS_PROMETHEUS_AUTH_HEADER=
AIOPS_ALERTMANAGER_AUTH_HEADER=
AIOPS_PROMETHEUS_TIMEOUT_SECONDS=20
AIOPS_PROMETHEUS_MAX_POINTS=500
AIOPS_PROMETHEUS_MAX_SERIES=50
AIOPS_PROMETHEUS_CPU_QUERY_TEMPLATE=100 * (1 - avg(rate(node_cpu_seconds_total{mode="idle"}[5m])))
AIOPS_PROMETHEUS_MEMORY_QUERY_TEMPLATE=100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))

# local_vps 采样保留给非 Prometheus 模式；Prometheus 模式下不依赖进程映射
AIOPS_LOCAL_SAMPLE_SECONDS=0.25
AIOPS_SERVICE_PROCESS_MAP={"oncall-agent":["uvicorn app.main:app"],"mcp-cls":["mcp_servers/cls_server.py"],"mcp-monitor":["mcp_servers/monitor_server.py"],"nginx":["nginx: master","nginx: worker"]}
