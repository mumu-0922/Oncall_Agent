# 应用配置
APP_NAME=SuperBizAgent
DEBUG=True
HOST=0.0.0.0
PORT=9900

# ============================================================
# Chat LLM 配置（推荐：OpenAI-compatible，中转/GPT/网关都走这里）
# ============================================================
# 当前你有 GPT 中转时，改这 4 个即可：
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://your-gateway.example/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=2

# DashScope 兼容旧配置；当 LLM_PROVIDER=dashscope 时可复用
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=

# OpenAI 官方直连可选
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================
# Embedding 配置
# ============================================================
# 没有 embedding key 时设 disabled：上传文档仍写 parent-child docstore + BM25，dense Milvus 跳过。
# 可选：disabled | dashscope | openai | openai_compatible
EMBEDDING_PROVIDER=disabled
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1024

# DashScope embedding 示例：
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_API_KEY=${DASHSCOPE_API_KEY}
# EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=1024

# OpenAI embedding 示例：
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=${OPENAI_API_KEY}
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Milvus 配置（embedding disabled 时启动可不依赖 Milvus）
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

# RAG 配置
RAG_TOP_K=3
# 无 embedding 推荐 hybrid_parent：dense 不可用会自动走 BM25-only + parent expansion
RAG_RETRIEVAL_MODE=hybrid_parent
RAG_DOCSTORE_DIR=data/rag
RAG_PARENT_MAX_CHARS=3500
RAG_CHILD_CHUNK_SIZE=500
RAG_CHILD_CHUNK_OVERLAP=80
RAG_DENSE_FETCH_K=10
RAG_BM25_FETCH_K=10
RAG_FINAL_TOP_K=3
RAG_DENSE_WEIGHT=0.6
RAG_BM25_WEIGHT=0.4
RAG_EXPAND_PARENT=true
RAG_PARENT_CONTEXT_MAX_CHARS=2500

# 兼容旧 RAG_MODEL；为空则使用 LLM_MODEL / DASHSCOPE_MODEL
RAG_MODEL=

# 文档分块配置（旧 dense splitter 兼容）
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# 对话上下文摘要配置
RAG_CONTEXT_SUMMARY_ENABLED=true
RAG_SUMMARY_TRIGGER_MESSAGES=12
RAG_SUMMARY_KEEP_MESSAGES=6
RAG_SUMMARY_TRIM_TOKENS=4000

# AIOps Agent 配置
# AIOps 不做 silent fallback：MCP/structured output/tool calling 不可用时直接报错。
AIOPS_STRUCTURED_OUTPUT_METHOD=function_calling
AIOPS_REQUIRE_TOOL_CALL=true
AIOPS_TOOL_CALL_MAX_ROUNDS=3
# 默认关闭 Executor 的二次 LLM 总结：工具结果直接作为步骤证据，避免网关慢响应导致诊断链路卡住。
AIOPS_EXECUTOR_SUMMARIZE_WITH_LLM=false

# MCP 服务配置
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# ============================================================
# AIOps 真实 WSL/Linux 本机采集（无 Prometheus/Loki 时的最短接入）
# ============================================================
# local_wsl/local_vps: Monitor 读取当前 Linux/WSL /proc；CLS 读取本机日志文件。
AIOPS_MONITOR_PROVIDER=local_wsl
AIOPS_LOG_PROVIDER=local_wsl
# 默认禁止 mock：数据源未配置时返回错误原因，不返回假数据。仅演示环境才可显式改 true。
AIOPS_ALLOW_MOCK=false
# Planner 问到未知服务名时，可 fallback 到这个默认服务，避免 core-business-service 这类泛称查空。
AIOPS_DEFAULT_SERVICE=super-biz-agent
# 服务名 -> 进程匹配关键字；多个关键字可用数组。
AIOPS_SERVICE_PROCESS_MAP={"super-biz-agent":["uvicorn app.main:app"],"mcp-cls":["mcp_servers/cls_server.py"],"mcp-monitor":["mcp_servers/monitor_server.py"],"nginx":["nginx: master","nginx: worker"]}
# 服务名 -> 日志文件路径；多个日志文件可用数组。
AIOPS_SERVICE_LOG_MAP={"super-biz-agent":["server.log","mcp_cls.log","mcp_monitor.log"],"nginx":["/var/log/nginx/error.log","/var/log/nginx/access.log"]}
# 采样 CPU 的间隔，越大越准但工具调用越慢。
AIOPS_LOCAL_SAMPLE_SECONDS=0.25
